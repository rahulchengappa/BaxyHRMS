@model HRMS.Domain.Entities.EmployeeDto
@using HRMS.Application.Interfaces.Security
@inject IIdProtector IdProtector

@{
    ViewData["Title"] = "Employee Details";
    var encryptedEmployeeId = IdProtector.Protect(Model.EmployeeID.ToString());
}

<div class="card p-3">
    <dl class="row">

        
        <dt class="col-sm-3">Employee Code</dt>
        <dd class="col-sm-9">@Model.EmployeeCode</dd>

        <dt class="col-sm-3">Full Name</dt>
        <dd class="col-sm-9">@Model.FirstName @Model.LastName</dd>

        <dt class="col-sm-3">Email</dt>
        <dd class="col-sm-9">@Model.Email</dd>

        <dt class="col-sm-3">Mobile</dt>
        <dd class="col-sm-9">@Model.MobileNumber</dd>

        <dt class="col-sm-3">Department</dt>
        <dd class="col-sm-9">@Model.DepartmentName</dd>

        <dt class="col-sm-3">Designation</dt>
        <dd class="col-sm-9">@Model.DesignationName</dd>

        <dt class="col-sm-3">Role</dt>
        <dd class="col-sm-9">@Model.RoleName</dd>

        <dt class="col-sm-3">Joining Date</dt>
        <dd class="col-sm-9">@Model.JoiningDate.ToShortDateString()</dd>

        <dt class="col-sm-3">Status</dt>
        <dd class="col-sm-9">@((Model.Status) ? "Active" : "Inactive")</dd>

        <dt class="col-sm-3">Created By</dt>
        <dd class="col-sm-9">@Model.CreatedBy</dd>

        <dt class="col-sm-3">Updated By</dt>
        <dd class="col-sm-9">@Model.UpdatedBy</dd>

    </dl>

    <a asp-action="Edit"
           asp-route-id="@encryptedEmployeeId"
           class="btn btn-warning">
        Edit
    </a>

    <a asp-action="Index" class="btn btn-secondary">Back</a>
    

</div>

<hr />

<h5 class="mt-3">Employee Documents</h5>

<form asp-action="UploadDocument" method="post" enctype="multipart/form-data">

    
    <input type="hidden" name="employeeId" value="@encryptedEmployeeId" />

    <div class="row mb-3">

        <div class="col-md-4">
            <label class="form-label">Document Type</label>
            <select name="documentType" class="form-control" required>
                <option value="">-- Select Document Type --</option>
                <option value="PAN Card">PAN Card</option>
                <option value="Aadhaar Card">Aadhaar Card</option>
                <option value="10th Certificate">10th Certificate</option>
                <option value="12th Certificate">12th Certificate</option>
                <option value="Degree Certificate">Degree Certificate</option>
            </select>
        </div>

        <div class="col-md-4">
            <label class="form-label">Upload File</label>
            <input type="file" name="file" class="form-control" required />

            <small class="text-muted">
                Max file size: 5 MB
            </small>
        </div>

        <div class="col-md-2 d-flex align-items-center">
            <button type="submit" class="btn btn-primary">Upload</button>
        </div>

    </div>
    

</form>

@if (Model.Documents != null && Model.Documents.Any())
{
    <table class="table table-bordered mt-3">

        
        <thead class="table-light">
            <tr>
                <th>Document Type</th>
                <th>File</th>
            </tr>
        </thead>

        <tbody>

            @foreach (var doc in Model.Documents)
            {
                <tr>
                    <td>@doc.DocumentType</td>

                    <td>
                        <a href="@doc.FilePath"
                               target="_blank"
                               class="btn btn-sm btn-info">
                            View
                        </a>
                        <a href="@doc.FilePath"
                               download
                               class="btn btn-sm btn-success">
                            Download
                        </a>

                        <form asp-action="DeleteDocument"
                              method="post"
                              style="display:inline;">

                            <input type="hidden"
                                   name="documentId"
                                   value="@IdProtector.Protect(doc.DocumentId.ToString())" />

                            <input type="hidden"
                                   name="employeeId"
                                   value="@encryptedEmployeeId" />

                            <button type="button"
                                    class="btn btn-sm btn-danger delete-btn"
                                    data-docid="@IdProtector.Protect(doc.DocumentId.ToString())"
                                    data-empid="@encryptedEmployeeId">
                                Delete
                            </button>

                        </form>
                    </td>
                </tr>
            }

        </tbody>

    </table>

}
else
{

    <p class="text-muted mt-3">No documents uploaded.</p>
}

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    document.querySelector('input[name="file"]').addEventListener('change', function () {
        const file = this.files[0];

        if (file) {
            const maxSize = 5 * 1024 * 1024; // 5MB

            if (file.size > maxSize) {
                    Swal.fire({
                        icon: 'error',
                        title: 'File Too Large',
                        text: 'File size must be less than 5 MB',
                        confirmButtonColor: '#3085d6'
                    });
                this.value = "";
            }
        }
    });
</script>

<script>
    document.querySelectorAll('.delete-btn').forEach(btn => {
        btn.addEventListener('click', function () {

            const docId = this.getAttribute('data-docid');
            const empId = this.getAttribute('data-empid');

            Swal.fire({
                title: 'Are you sure?',
                text: "This document will be deleted",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Yes, delete it'
            }).then((result) => {
                if (result.isConfirmed) {

                    const form = document.createElement('form');
                    form.method = 'post';
                    form.action = '/Employee/DeleteDocument';

                    form.innerHTML = `
                        <input type="hidden" name="documentId" value="${docId}" />
                        <input type="hidden" name="employeeId" value="${empId}" />
                    `;

                    document.body.appendChild(form);
                    form.submit();
                }
            });
        });
    });
</script>

@if (TempData["EmployeeSuccess"] != null)
{
    <script>
        Swal.fire({
            icon: 'success',
            title: 'Success',
            text: '@TempData["EmployeeSuccess"]'
        });
    </script>
}

@if (TempData["EmployeeError"] != null)
{
    <script>
        Swal.fire({
            icon: 'error',
            title: 'Error',
            text: '@TempData["EmployeeError"]'
        });
    </script>
}