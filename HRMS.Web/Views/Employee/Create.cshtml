@model HRMS.Domain.Entities.EmployeeDto

@{
    ViewData["Title"] = "Create Employee";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-10">

            <form asp-action="Create" method="post">

                <!-- ERROR MESSAGE -->
                @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
                {
                    <!--  FIXED ALERT -->
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        @(ViewData.ModelState.Values
                            .SelectMany(v => v.Errors)
                            .FirstOrDefault()?.ErrorMessage)

                        <button type="button"
                                class="btn-close"
                                data-bs-dismiss="alert"
                                aria-label="Close">
                        </button>
                    </div>
                }

                <!-- BASIC INFORMATION -->
                <div class="card mb-4 shadow-sm">
                    <div class="card-header bg-primary text-white">
                        Employee Info
                    </div>
                    <div class="card-body">

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label>Employee Code</label>
                                <input asp-for="EmployeeCode" class="form-control" />
                                <span asp-validation-for="EmployeeCode" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label>Email</label>
                                <input asp-for="Email" class="form-control" />
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label>First Name</label>
                                <input asp-for="FirstName" class="form-control" />
                                <span asp-validation-for="FirstName" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label>Last Name</label>
                                <input asp-for="LastName" class="form-control" />
                                <span asp-validation-for="LastName" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label>Mobile Number</label>
                            <input asp-for="MobileNumber" class="form-control" />
                            <span asp-validation-for="MobileNumber" class="text-danger"></span>
                        </div>

                    </div>
                </div>

                <!-- JOB DETAILS -->
                <div class="card mb-4 shadow-sm">
                    <div class="card-header bg-success text-white">
                        Job Details
                    </div>
                    <div class="card-body">

                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label>Department</label>
                                <select asp-for="DepartmentId"
                                        asp-items="ViewBag.Departments"
                                        class="form-select">
                                    <option value="">-- Select Department --</option>
                                </select>
                                <span asp-validation-for="DepartmentId" class="text-danger"></span>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label>Designation</label>
                                <select asp-for="DesignationId"
                                        asp-items="ViewBag.Designations"
                                        class="form-select">
                                    <option value="">-- Select Designation --</option>
                                </select>
                                <span asp-validation-for="DesignationId" class="text-danger"></span>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label>Role</label>
                                <select asp-for="RoleId"
                                        asp-items="ViewBag.Roles"
                                        class="form-select">
                                    <option value="">-- Select Role --</option>
                                </select>
                                <span asp-validation-for="RoleId" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label>Joining Date</label>
                                <input asp-for="JoiningDate" type="date" class="form-control" />
                                <span asp-validation-for="JoiningDate" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label>Status</label>
                                <select asp-for="Status" class="form-select">
                                    <option value="true">Active</option>
                                    <option value="false">Inactive</option>
                                </select>
                                <span asp-validation-for="Status" class="text-danger"></span>
                            </div>
                        </div>

                    </div>
                </div>

                <!-- REPORTING STRUCTURE -->
                <div class="card mb-4 shadow-sm">
                    <div class="card-header bg-warning text-dark">
                        Reporting Details
                    </div>
                    <div class="card-body">

                        <div class="mb-3">
                            <label>Reporting Manager</label>
                            <select asp-for="ReportingManagerId"
                                    asp-items="ViewBag.Managers"
                                    class="form-select">
                                <option value="">-- Select Manager --</option>
                            </select>
                            <span asp-validation-for="ReportingManagerId" class="text-danger"></span>
                        </div>

                    </div>
                </div>

                <!-- ACCOUNT DETAILS -->
                <div class="card mb-4 shadow-sm">
                    <div class="card-header bg-danger text-white">
                        Account Details
                    </div>
                    <div class="card-body">

                        <div class="mb-3">
                            <label>Username</label>
                            <input asp-for="Username" class="form-control" />
                            <span asp-validation-for="Username" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label>Password</label>
                            <input asp-for="Password" type="password" class="form-control" />
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>

                    </div>
                </div>

                <!-- ACTION BUTTONS -->
                <div class="text-end">
                    <button type="submit" class="btn btn-success px-4">Save</button>
                    <a asp-action="Index" class="btn btn-secondary px-4">
                        Back to List
                    </a>
                </div>

            </form>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}