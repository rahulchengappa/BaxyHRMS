@model HRMS.Domain.Entities.EmployeeDto
@using HRMS.Application.Interfaces.Security
@inject IIdProtector IdProtector

@{
    ViewData["Title"] = "Edit Employee";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-10">

            <form asp-action="Edit" method="post">

                @if (TempData["EmployeeSuccess"] is string success)
                {
                    TempData.Remove("EmployeeSuccess");

                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        @success
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }


                @if (TempData["EmployeeError"] is string error)
                {
                    TempData.Remove("EmployeeError");

                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        @error
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                <!-- Encrypted ID -->
                <input type="hidden"
                       name="EncryptedEmployeeID"
                       value="@IdProtector.Protect(Model.EmployeeID.ToString())" />

                <!-- BASIC INFORMATION -->
                <div class="card mb-4 shadow-sm">
                    <div class="card-header bg-primary text-white">
                        Employee Info
                    </div>
                    <div class="card-body">

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label>Employee Code</label>
                                <input asp-for="EmployeeCode" class="form-control" />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label>Email</label>
                                <input asp-for="Email" class="form-control" />
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label>First Name</label>
                                <input asp-for="FirstName" class="form-control" />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label>Last Name</label>
                                <input asp-for="LastName" class="form-control" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label>Mobile Number</label>
                            <input asp-for="MobileNumber" class="form-control" />
                        </div>

                    </div>
                </div>


                <!-- JOB DETAILS -->
                <div class="card mb-4 shadow-sm">
                    <div class="card-header bg-success text-white">
                        Job Details
                    </div>
                    <div class="card-body">

                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label>Department</label>
                                <select asp-for="DepartmentId"
                                        asp-items="ViewBag.Departments"
                                        class="form-select">
                                    <option value="">-- Select Department --</option>
                                </select>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label>Designation</label>
                                <select asp-for="DesignationId"
                                        asp-items="ViewBag.Designations"
                                        class="form-select">
                                    <option value="">-- Select Designation --</option>
                                </select>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label>Role</label>
                                <select asp-for="RoleId"
                                        asp-items="ViewBag.Roles"
                                        class="form-select">
                                    <option value="">-- Select Role --</option>
                                </select>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label>Joining Date</label>
                                <input asp-for="JoiningDate" type="date" class="form-control" />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label>Status</label>
                                <select asp-for="Status" class="form-select">
                                    <option value="true">Active</option>
                                    <option value="false">Inactive</option>
                                </select>
                            </div>
                        </div>

                    </div>
                </div>


                <!-- REPORTING STRUCTURE -->
                <div class="card mb-4 shadow-sm">
                    <div class="card-header bg-warning text-dark">
                        Reporting Details
                    </div>
                    <div class="card-body">

                        <div class="mb-3">
                            <label>Reporting Manager</label>
                            <select asp-for="ReportingManagerId"
                                    asp-items="ViewBag.Managers"
                                    class="form-select">
                                <option value="">-- Select Manager --</option>
                            </select>
                        </div>

                    </div>
                </div>


                <!-- ACTION BUTTONS -->
                <div class="text-end">
                    <button type="submit" class="btn btn-primary px-4">
                        Save Changes
                    </button>

                    <a asp-action="Index" class="btn btn-secondary px-4">
                        ← Back to List
                    </a>
                </div>

            </form>

        </div>
    </div>
</div>