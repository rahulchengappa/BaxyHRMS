@model HRMS.Domain.Entities.EmployeeDto
@using HRMS.Application.Interfaces.Security
@inject IIdProtector IdProtector

@{
    ViewData["Title"] = "Delete Employee";
}

<div class="alert alert-danger py-2 px-3 small d-inline-block w-auto mb-3">
    Are you sure you want to delete this employee?
</div>

<div class="card p-3">
    <p><strong>@Model.FirstName @Model.LastName</strong></p>
    <p>Email: @Model.Email</p>
    <p>Department: @Model.DepartmentName</p>
    <p>Designation: @Model.DesignationName</p>
</div>

<form asp-action="Delete" method="post">
    <!-- ENCRYPTED EMPLOYEE ID -->
    <input type="hidden"
           name="id"
           value="@IdProtector.Protect(Model.EmployeeID.ToString())" />

    <br />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
