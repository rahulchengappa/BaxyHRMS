@model HRMS.Domain.Entities.EmployeeDto
@using System.Security.Claims

@{
    Layout = "_LayoutDashboard";

    var employeeId =
        User.FindFirst("EmployeeId")?.Value;
}



<div class="container mt-2">
    <div class="row justify-content-center">
        <div class="col-auto">

            @if (TempData["ProfileSuccess"] != null)
            {
                <div style="display:flex; justify-content:center; margin-bottom:10px;">
                    <div class="alert alert-success fade show d-inline-flex align-items-center gap-2 px-3 py-2 small mb-0"
                         style="width:fit-content; position:relative;">

                        <span>@TempData["ProfileSuccess"]</span>

                        <button type="button"
                                data-bs-dismiss="alert"
                                style="
                            border:none;
                            background:none;
                            font-size:16px;
                            line-height:1;
                            margin-left:8px;
                            cursor:pointer;">
                            ×
                        </button>
                    </div>
                </div>
            }

            @if (TempData["ProfileError"] != null)
            {
                <div style="display:flex; justify-content:center; margin-bottom:10px;">
                    <div class="alert alert-danger fade show d-inline-flex align-items-center gap-2 px-3 py-2 small mb-0"
                         style="width:fit-content; position:relative;">

                        <span>@TempData["ProfileError"]</span>

                        <button type="button"
                                data-bs-dismiss="alert"
                                style="
                            border:none;
                            background:none;
                            font-size:16px;
                            line-height:1;
                            margin-left:8px;
                            cursor:pointer;">
                            ×
                        </button>
                    </div>
                </div>
            }


        </div>
    </div>
</div>




    <!-- TOP RIGHT BACK BUTTON -->
    <div class="d-flex justify-content-end mb-3">
        <a href="/Home/Dashboard" class="btn btn-secondary">
            ← Back to Dashboard
        </a>
    </div>

    <h2 class="mb-4">My Profile</h2>

    <div class="card shadow-sm p-4">
        <div class="row">

            <!-- LEFT PROFILE IMAGE -->
            <div class="col-md-3 text-center">

                <img src="@ViewBag.PhotoToShow"
                     class="rounded-circle mb-3"
                     width="140" height="140" />

                <form asp-controller="Profile"
                      asp-action="UploadPhoto"
                      enctype="multipart/form-data"
                      method="post">

                    <input type="file"
                           name="photo"
                           class="form-control mb-2"
                           accept="image/*" />

                    <button class="btn btn-primary btn-sm w-100">
                        Upload
                    </button>
                </form>

                <form asp-controller="Profile"
                      asp-action="RemovePhoto"
                      method="post">

                    <button class="btn btn-outline-danger btn-sm w-100 mt-2">
                        Remove Photo
                    </button>
                </form>

            </div>

            <!-- RIGHT USER DETAILS -->
            <div class="col-md-9">
                <h5><strong>Name:</strong> @Model.FirstName @Model.LastName</h5>
                <h5 class="mt-2"><strong>Email:</strong> @Model.Email</h5>

                <div class="mt-4">
                    
                    <a href="/Profile/ChangePassword"
                       class="btn btn-primary btn-sm ms-2">
                        <i class="fa fa-lock me-1"></i> Change Password
                    </a>
                </div>
            </div>

        </div>
    </div>


